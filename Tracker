<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#000000">
<title>HYROX Tracker</title>
<link rel="manifest" href="data:application/json;base64,">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
  *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
  :root{
    --bg:#f2f2f7;--card:#fff;--text:#1c1c1e;--text2:#8e8e93;--text3:#aeaeb2;
    --accent:#ff6b35;--accent2:#ff9500;--green:#34c759;--blue:#007aff;
    --purple:#af52de;--red:#ff3b30;--pink:#ff2d55;--teal:#5ac8fa;--indigo:#5856d6;
    --border:rgba(60,60,67,.08);--shadow:0 1px 12px rgba(0,0,0,.06);
    --radius:16px;--radius-sm:12px;
    --font:-apple-system,BlinkMacSystemFont,'SF Pro Display','SF Pro Text','Helvetica Neue',sans-serif;
  }
  @media(prefers-color-scheme:dark){
    :root{--bg:#000;--card:#1c1c1e;--text:#f5f5f7;--text2:#98989d;--text3:#636366;
    --border:rgba(255,255,255,.06);--shadow:0 1px 12px rgba(0,0,0,.3)}
  }
  html{font-size:16px}
  body{font-family:var(--font);background:var(--bg);color:var(--text);
    min-height:100dvh;-webkit-font-smoothing:antialiased;
    padding-bottom:100px;overflow-x:hidden}

  .header{position:sticky;top:0;z-index:100;
    backdrop-filter:blur(24px) saturate(180%);-webkit-backdrop-filter:blur(24px) saturate(180%);
    background:rgba(242,242,247,.75);border-bottom:.5px solid var(--border);
    padding:12px 20px 14px}
  @media(prefers-color-scheme:dark){.header{background:rgba(0,0,0,.75)}}
  .header-row{display:flex;align-items:center;justify-content:space-between}
  .header h1{font-size:28px;font-weight:700;letter-spacing:-.4px}
  .header-date{font-size:13px;color:var(--text2);font-weight:500;margin-top:2px}
  .header-actions{display:flex;gap:8px;align-items:center}
  .header-badge{background:var(--accent);color:#fff;font-size:11px;font-weight:700;
    padding:5px 12px;border-radius:20px}
  .icon-btn{background:rgba(120,120,128,.12);border:none;width:34px;height:34px;
    border-radius:50%;display:flex;align-items:center;justify-content:center;
    cursor:pointer;font-size:16px;color:var(--text);transition:transform .15s}
  .icon-btn:active{transform:scale(.9)}

  .countdown{margin:16px 16px 8px;background:var(--card);border-radius:var(--radius);
    padding:20px;box-shadow:var(--shadow);position:relative;overflow:hidden}
  .countdown::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;
    background:linear-gradient(90deg,var(--accent),var(--accent2))}
  .countdown-inner{display:flex;align-items:center;justify-content:space-between}
  .countdown h3{font-size:11px;color:var(--text2);font-weight:700;
    text-transform:uppercase;letter-spacing:1.2px;margin-bottom:4px}
  .countdown .big{font-size:44px;font-weight:800;letter-spacing:-2px;line-height:1;
    background:linear-gradient(135deg,var(--accent),var(--accent2));
    -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
  .countdown .unit{font-size:14px;color:var(--text2);font-weight:500;margin-top:2px}
  .mini-progress{width:60px;height:60px;position:relative}
  .mini-progress svg{transform:rotate(-90deg);width:60px;height:60px}
  .mini-progress circle{fill:none;stroke-width:5}
  .mini-progress .bg{stroke:var(--border)}
  .mini-progress .fg{stroke:var(--accent);stroke-linecap:round;transition:stroke-dashoffset 1s ease}
  .mini-progress .val{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
    font-size:13px;font-weight:700;color:var(--accent)}

  .tab-bar{position:fixed;bottom:0;left:0;right:0;z-index:200;
    backdrop-filter:blur(24px) saturate(180%);-webkit-backdrop-filter:blur(24px) saturate(180%);
    background:rgba(242,242,247,.8);border-top:.5px solid var(--border);
    display:flex;justify-content:space-around;
    padding:6px 0 calc(8px + env(safe-area-inset-bottom))}
  @media(prefers-color-scheme:dark){.tab-bar{background:rgba(28,28,30,.88)}}
  .tab{background:none;border:none;display:flex;flex-direction:column;align-items:center;
    gap:2px;padding:6px 10px;cursor:pointer;color:var(--text3);font-size:10px;
    font-weight:500;font-family:var(--font);-webkit-tap-highlight-color:transparent;
    transition:color .2s}
  .tab.active{color:var(--accent)}
  .tab svg{width:22px;height:22px;fill:currentColor}

  .page{display:none;padding:8px 16px 24px;animation:fadeUp .35s ease}
  .page.active{display:block}
  @keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}
  .sec-title{font-size:20px;font-weight:700;letter-spacing:-.3px;margin:20px 0 12px}
  .sec-label{font-size:11px;color:var(--text2);font-weight:700;text-transform:uppercase;
    letter-spacing:1px;margin:20px 0 10px}

  .card{background:var(--card);border-radius:var(--radius);padding:16px;
    box-shadow:var(--shadow);margin-bottom:10px;transition:transform .15s}
  .card:active{transform:scale(.98)}
  .card-row{display:flex;align-items:center;gap:12px}
  .card-icon{width:40px;height:40px;border-radius:10px;display:flex;
    align-items:center;justify-content:center;flex-shrink:0;font-size:18px}
  .card-info{flex:1;min-width:0}
  .card-info h4{font-size:15px;font-weight:600;margin-bottom:1px}
  .card-info p{font-size:12px;color:var(--text2)}
  .card-val{text-align:right;white-space:nowrap}
  .card-val .num{font-size:22px;font-weight:700;display:block;line-height:1.1}
  .card-val .lbl{font-size:11px;color:var(--text2);font-weight:500}

  .grid2{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px}
  .stat{background:var(--card);border-radius:var(--radius);padding:16px;box-shadow:var(--shadow)}
  .stat .ico{font-size:12px;color:var(--text2);font-weight:600;display:flex;align-items:center;
    gap:5px;margin-bottom:8px}
  .stat .ico span{font-size:16px}
  .stat .val{font-size:26px;font-weight:800;letter-spacing:-1px;line-height:1}
  .stat .lbl{font-size:11px;color:var(--text2);font-weight:500;margin-top:3px}

  .week{display:grid;grid-template-columns:repeat(7,1fr);gap:6px;margin-bottom:16px}
  .day{text-align:center;padding:10px 0 8px;border-radius:12px;background:var(--card);
    box-shadow:var(--shadow);cursor:pointer;transition:transform .15s}
  .day:active{transform:scale(.92)}
  .day .dl{font-size:10px;color:var(--text2);font-weight:600;text-transform:uppercase}
  .day .dn{font-size:15px;font-weight:700;margin:3px 0}
  .day .dot{width:6px;height:6px;border-radius:50%;margin:0 auto;background:transparent}
  .day.done .dot{background:var(--green)}
  .day.today{outline:2px solid var(--accent);outline-offset:-2px}
  .day.missed .dot{background:var(--red)}
  .day.rest .dot{background:var(--text3);opacity:.3}
  .day.rescheduled .dot{background:var(--accent2)}

  .rings{display:flex;justify-content:space-around;margin:16px 0 20px}
  .ring-item{text-align:center}
  .ring-wrap{width:76px;height:76px;position:relative;margin:0 auto 6px}
  .ring-wrap svg{transform:rotate(-90deg);width:76px;height:76px}
  .ring-wrap circle{fill:none;stroke-width:6}
  .ring-wrap .bg{stroke:var(--border)}
  .ring-wrap .fg{stroke-linecap:round;transition:stroke-dashoffset .8s ease}
  .ring-wrap .cv{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
    font-size:15px;font-weight:700}
  .ring-item .rl{font-size:11px;color:var(--text2);font-weight:600}

  .prog-bar{height:6px;border-radius:3px;background:var(--border);overflow:hidden;margin-top:8px}
  .prog-bar .fill{height:100%;border-radius:3px;transition:width .6s ease}

  .log-item{display:flex;align-items:center;gap:12px;padding:14px 0;
    border-bottom:.5px solid var(--border)}
  .log-item:last-child{border-bottom:none}
  .log-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
  .log-body{flex:1;min-width:0}
  .log-body h4{font-size:14px;font-weight:600}
  .log-body p{font-size:12px;color:var(--text2)}
  .log-right{font-size:13px;font-weight:600;color:var(--text2);white-space:nowrap}

  .chart-container{background:var(--card);border-radius:var(--radius);padding:16px;
    box-shadow:var(--shadow);margin-bottom:12px;position:relative}
  .chart-container canvas{max-height:220px}

  .empty{text-align:center;padding:40px 20px;color:var(--text2)}
  .empty .emoji{font-size:48px;margin-bottom:12px}
  .empty p{font-size:14px;line-height:1.5}

  .cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;margin-bottom:16px}
  .cal-header{text-align:center;font-size:10px;font-weight:700;color:var(--text2);
    text-transform:uppercase;padding:8px 0}
  .cal-day{text-align:center;padding:8px 2px;border-radius:10px;font-size:13px;
    font-weight:600;cursor:pointer;transition:all .15s;min-height:44px;
    display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px}
  .cal-day:hover{background:var(--border)}
  .cal-day.today-cal{background:var(--accent);color:#fff;border-radius:10px}
  .cal-day.has-training::after{content:'';width:5px;height:5px;border-radius:50%;
    background:var(--green);display:block}
  .cal-day.has-missed::after{content:'';width:5px;height:5px;border-radius:50%;
    background:var(--red);display:block}
  .cal-day.has-rescheduled::after{content:'';width:5px;height:5px;border-radius:50%;
    background:var(--accent2);display:block}
  .cal-day.empty-day{opacity:0;pointer-events:none}
  .cal-nav{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
  .cal-nav h3{font-size:17px;font-weight:700}
  .cal-nav button{background:none;border:none;font-size:20px;cursor:pointer;
    color:var(--accent);padding:8px;font-weight:700}

  .modal-bg{display:none;position:fixed;inset:0;z-index:500;background:rgba(0,0,0,.45);
    backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);
    align-items:flex-end;justify-content:center}
  .modal-bg.open{display:flex}
  .modal{background:var(--card);border-radius:20px 20px 0 0;width:100%;max-width:500px;
    padding:20px 20px calc(20px + env(safe-area-inset-bottom));
    max-height:85dvh;overflow-y:auto;animation:slideUp .35s ease}
  @keyframes slideUp{from{transform:translateY(100%)}to{transform:none}}
  .modal-handle{width:36px;height:4px;border-radius:2px;background:var(--text3);
    margin:0 auto 16px;opacity:.4}
  .modal h2{font-size:20px;font-weight:700;margin-bottom:16px}
  .field{margin-bottom:14px}
  .field label{display:block;font-size:12px;font-weight:600;color:var(--text2);
    margin-bottom:6px;text-transform:uppercase;letter-spacing:.5px}
  .field input,.field select,.field textarea{width:100%;padding:12px 14px;
    border-radius:var(--radius-sm);border:1px solid var(--border);
    background:var(--bg);color:var(--text);font-size:16px;font-family:var(--font);
    -webkit-appearance:none;appearance:none;outline:none;transition:border .2s}
  .field input:focus,.field select:focus,.field textarea:focus{border-color:var(--accent)}
  .field textarea{resize:vertical;min-height:60px}
  .btn{width:100%;padding:14px;border:none;border-radius:var(--radius-sm);
    font-size:16px;font-weight:600;font-family:var(--font);cursor:pointer;
    transition:transform .1s,opacity .2s;margin-bottom:8px}
  .btn:active{transform:scale(.97)}
  .btn-primary{background:var(--accent);color:#fff}
  .btn-ghost{background:transparent;color:var(--red)}
  .btn-secondary{background:rgba(120,120,128,.12);color:var(--text)}

  .fab{position:fixed;bottom:90px;right:20px;z-index:150;width:52px;height:52px;
    border-radius:50%;background:var(--accent);color:#fff;border:none;font-size:28px;
    display:flex;align-items:center;justify-content:center;
    box-shadow:0 4px 20px rgba(255,107,53,.35);cursor:pointer;transition:transform .15s}
  .fab:active{transform:scale(.9)}

  .toast{position:fixed;top:60px;left:50%;transform:translateX(-50%) translateY(-80px);
    z-index:600;background:var(--card);color:var(--text);padding:12px 24px;
    border-radius:20px;font-size:14px;font-weight:600;box-shadow:0 8px 32px rgba(0,0,0,.15);
    opacity:0;transition:all .4s ease;pointer-events:none}
  .toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

  .sync-status{font-size:10px;color:var(--text3);text-align:center;padding:4px;font-weight:500}
  .sync-status.ok{color:var(--green)}
  .sync-status.err{color:var(--red)}

  .goal-row{display:flex;align-items:center;justify-content:space-between;
    padding:12px 0;border-bottom:.5px solid var(--border)}
  .goal-row:last-child{border-bottom:none}
  .goal-row .g-label{font-size:14px;font-weight:600}
  .goal-row .g-input{width:80px;padding:8px 10px;border-radius:10px;border:1px solid var(--border);
    background:var(--bg);color:var(--text);font-size:15px;font-weight:600;text-align:center;
    font-family:var(--font)}

  .chip-row{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px}
  .chip{padding:6px 14px;border-radius:20px;font-size:12px;font-weight:600;
    cursor:pointer;border:1.5px solid var(--border);background:var(--card);
    color:var(--text2);transition:all .2s}
  .chip.active{border-color:var(--accent);background:rgba(255,107,53,.1);color:var(--accent)}

  .tdee-card{background:var(--card);border-radius:var(--radius);padding:16px;
    box-shadow:var(--shadow);margin-bottom:10px}
  .tdee-card .tdee-num{font-size:32px;font-weight:800;letter-spacing:-1px;
    background:linear-gradient(135deg,var(--green),var(--teal));
    -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
  .tdee-card .tdee-row{display:flex;justify-content:space-between;padding:6px 0;
    font-size:13px;border-bottom:.5px solid var(--border)}
  .tdee-card .tdee-row:last-child{border-bottom:none}
  .tdee-card .tdee-row span:first-child{color:var(--text2)}
  .tdee-card .tdee-row span:last-child{font-weight:600}
</style>
</head>
<body>

<header class="header">
  <div class="header-row">
    <div>
      <div class="header-date" id="headerDate"></div>
      <h1>HYROX Tracker</h1>
    </div>
    <div class="header-actions">
      <span class="header-badge" id="phaseBadge">PHASE 1</span>
      <button class="icon-btn" onclick="openModal('modalSettings')" title="Réglages">⚙️</button>
      <button class="icon-btn" onclick="exportCSV()" title="Export CSV">📥</button>
    </div>
  </div>
  <div class="sync-status" id="syncStatus">—</div>
</header>

<div class="countdown">
  <div class="countdown-inner">
    <div>
      <h3>Jour de course</h3>
      <div class="big" id="daysLeft">—</div>
      <div class="unit">jours restants</div>
    </div>
    <div>
      <div class="mini-progress">
        <svg viewBox="0 0 60 60">
          <circle class="bg" cx="30" cy="30" r="25"/>
          <circle class="fg" id="countRing" cx="30" cy="30" r="25"
            stroke-dasharray="157" stroke-dashoffset="157"/>
        </svg>
        <div class="val" id="countPct">0%</div>
      </div>
    </div>
  </div>
</div>

<!-- PAGE: DASHBOARD -->
<section class="page active" id="pageDash">
  <div class="sec-label">Cette semaine</div>
  <div class="week" id="weekGrid"></div>
  <div class="sec-label">Anneaux du jour</div>
  <div class="rings">
    <div class="ring-item">
      <div class="ring-wrap"><svg viewBox="0 0 76 76"><circle class="bg" cx="38" cy="38" r="30"/>
        <circle class="fg" id="ringTrain" cx="38" cy="38" r="30" stroke="var(--accent)"
          stroke-dasharray="188.5" stroke-dashoffset="188.5"/></svg>
        <div class="cv" style="color:var(--accent)" id="ringTrainVal">0</div>
      </div><div class="rl">Entraînement</div></div>
    <div class="ring-item">
      <div class="ring-wrap"><svg viewBox="0 0 76 76"><circle class="bg" cx="38" cy="38" r="30"/>
        <circle class="fg" id="ringSleep" cx="38" cy="38" r="30" stroke="var(--purple)"
          stroke-dasharray="188.5" stroke-dashoffset="188.5"/></svg>
        <div class="cv" style="color:var(--purple)" id="ringSleepVal">—</div>
      </div><div class="rl">Sommeil</div></div>
    <div class="ring-item">
      <div class="ring-wrap"><svg viewBox="0 0 76 76"><circle class="bg" cx="38" cy="38" r="30"/>
        <circle class="fg" id="ringCal" cx="38" cy="38" r="30" stroke="var(--green)"
          stroke-dasharray="188.5" stroke-dashoffset="188.5"/></svg>
        <div class="cv" style="color:var(--green)" id="ringCalVal">0g</div>
      </div><div class="rl">Protéines</div></div>
  </div>

  <div class="sec-label">Dépense calorique estimée aujourd'hui</div>
  <div class="tdee-card" id="tdeeCard">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
      <div><div style="font-size:11px;color:var(--text2);font-weight:700;text-transform:uppercase;letter-spacing:1px">TDEE du jour</div>
        <div class="tdee-num" id="tdeeValue">— kcal</div></div>
      <div style="text-align:right"><div style="font-size:11px;color:var(--text2);font-weight:600">Objectif</div>
        <div style="font-size:20px;font-weight:700;color:var(--accent)" id="tdeeTarget">— kcal</div></div>
    </div>
    <div class="tdee-row"><span>Métabolisme basal</span><span id="tdeeBMR">—</span></div>
    <div class="tdee-row"><span>Activité quotidienne</span><span id="tdeeNEAT">—</span></div>
    <div class="tdee-row"><span>Effet thermique</span><span id="tdeeTEF">—</span></div>
    <div class="tdee-row"><span>Exercice du jour</span><span id="tdeeEAT">—</span></div>
    <div class="tdee-row"><span>🥩 Protéines recommandées</span><span id="tdeeProtein">—</span></div>
    <div class="tdee-row"><span>🍚 Glucides recommandés</span><span id="tdeeCarbs">—</span></div>
    <div class="tdee-row"><span>🥑 Lipides recommandés</span><span id="tdeeFat">—</span></div>
  </div>

  <div class="sec-label">Poids</div>
  <div class="card">
    <div class="card-row">
      <div class="card-icon" style="background:rgba(255,107,53,.12)">⚖️</div>
      <div class="card-info"><h4 id="weightCurrent">— kg</h4><p id="weightDelta">Pas de données</p></div>
      <div class="card-val"><span class="lbl">Objectif</span>
        <span class="num" style="font-size:16px;color:var(--accent)" id="weightGoalDisplay">65 kg</span></div>
    </div>
    <div class="prog-bar" style="margin-top:12px"><div class="fill" id="weightBar" style="width:0%;background:var(--accent)"></div></div>
  </div>

  <div class="sec-label">Tendances — 14 jours</div>
  <div class="chip-row">
    <div class="chip active" onclick="switchChart('weight',this)">Poids</div>
    <div class="chip" onclick="switchChart('sleep',this)">Sommeil</div>
    <div class="chip" onclick="switchChart('protein',this)">Protéines</div>
    <div class="chip" onclick="switchChart('training',this)">Entraînement</div>
    <div class="chip" onclick="switchChart('calories',this)">Calories</div>
  </div>
  <div class="chart-container"><canvas id="mainChart"></canvas></div>
</section>

<!-- PAGE: TRAINING -->
<section class="page" id="pageTrain">
  <div class="sec-title">Entraînements</div>
  <div class="sec-label">Aujourd'hui</div>
  <div id="todayPlan"></div>
  <div class="sec-label">Cette semaine</div>
  <div class="chart-container"><canvas id="trainWeekChart"></canvas></div>
  <div class="sec-label">Historique</div>
  <div class="card" id="trainLog"><div class="empty"><div class="emoji">🏋️</div><p>Aucun entraînement enregistré.</p></div></div>
</section>

<!-- PAGE: CALENDAR -->
<section class="page" id="pageCal">
  <div class="sec-title">Calendrier</div>
  <div class="card">
    <div class="cal-nav">
      <button onclick="changeMonth(-1)">‹</button>
      <h3 id="calTitle"></h3>
      <button onclick="changeMonth(1)">›</button>
    </div>
    <div class="cal-grid" id="calGrid"></div>
  </div>
  <div style="margin-top:12px">
    <button class="btn btn-secondary" onclick="syncGoogleCalendar()">📅 Synchroniser Google Calendar</button>
  </div>
  <div class="sec-label">Séances reportées</div>
  <div class="card" id="rescheduledList"><div class="empty"><div class="emoji">✅</div><p>Aucune séance reportée.</p></div></div>
</section>

<!-- PAGE: SLEEP -->
<section class="page" id="pageSleep">
  <div class="sec-title">Sommeil</div>
  <div class="grid2">
    <div class="stat"><div class="ico"><span>🛏️</span> Moyenne</div>
      <div class="val" id="sleepAvg">—</div><div class="lbl">heures / nuit</div></div>
    <div class="stat"><div class="ico"><span>🎯</span> Objectif</div>
      <div class="val" style="color:var(--purple)" id="sleepGoalDisplay">7h</div><div class="lbl">minimum</div></div>
  </div>
