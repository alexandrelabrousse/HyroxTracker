  $('tdeeBMR').textContent=t.bmr+' kcal';$('tdeeNEAT').textContent=t.neat+' kcal';
  $('tdeeTEF').textContent=t.tef+' kcal';$('tdeeEAT').textContent=t.eat+' kcal';
  $('tdeeProtein').textContent=t.protein+'g ('+t.protein*4+' kcal)';
  $('tdeeCarbs').textContent=t.carbs+'g ('+t.carbs*4+' kcal)';
  $('tdeeFat').textContent=t.fat+'g ('+t.fat*9+' kcal)';}
function renderWeight(){
  $('weightGoalDisplay').textContent=goals.weight+' kg';
  if(!data.weights.length){$('weightCurrent').textContent='— kg';$('weightDelta').textContent='Pas de données';$('weightBar').style.width='0%';return}
  const sorted=[...data.weights].sort((a,b)=>a.date.localeCompare(b.date)),last=sorted[sorted.length-1];
  $('weightCurrent').textContent=last.weight+' kg';
