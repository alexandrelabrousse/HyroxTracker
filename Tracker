<script>
const STORE='hyrox_v4',RACE=new Date('2025-10-04'),START=new Date('2025-04-07'),START_W=73;
let data,goals,profile,charts={},calMonth=new Date().getMonth(),calYear=new Date().getFullYear(),currentChart='weight';

function ld(){try{return JSON.parse(localStorage.getItem(STORE))||dd()}catch{return dd()}}
function dd(){return{trainings:[],sleep:[],meals:[],weights:[],missed:[]}}
function sv(){localStorage.setItem(STORE,JSON.stringify(data))}
function ldGoals(){try{return JSON.parse(localStorage.getItem('hyrox_goals'))||dg()}catch{return dg()}}
function dg(){return{protein:140,calories:2000,water:2.5,sleep:7,weight:65}}
function svGoals(){localStorage.setItem('hyrox_goals',JSON.stringify(goals))}
function ldProfile(){try{return JSON.parse(localStorage.getItem('hyrox_profile'))||dp()}catch{return dp()}}
function dp(){return{height:168,age:23,steps:6000}}
function svProfile(){localStorage.setItem('hyrox_profile',JSON.stringify(profile))}

data=ld();goals=ldGoals();profile=ldProfile();

function today(){return new Date().toISOString().split('T')[0]}
function todayE(a){return a.filter(e=>e.date===today())}
function $(id){return document.getElementById(id)}
function toast(m){const t=$('toast');t.textContent=m;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2200)}
function fmt(d){const m=['jan','fév','mar','avr','mai','jun','jul','aoû','sep','oct','nov','déc'],
  j=['Dim','Lun','Mar','Mer','Jeu','Ven','Sam'],dt=new Date(d+'T12:00:00');
  return`${j[dt.getDay()]} ${dt.getDate()} ${m[dt.getMonth()]}`}
function toMin(t){const[h,m]=t.split(':').map(Number);return h*60+m}

function loadGoalsUI(){
  $('goalPro').value=goals.protein;$('goalCal').value=goals.calories;
  $('goalWater').value=goals.water;$('goalSleep').value=goals.sleep;$('goalWeight').value=goals.weight;
  $('profileHeight').value=profile.height;$('profileAge').value=profile.age;$('profileSteps').value=profile.steps;
  const at=JSON.parse(localStorage.getItem('airtable_cfg')||'{}');
  if(at.key)$('airtableKey').value=at.key;if(at.base)$('airtableBase').value=at.base;
  if(at.table)$('airtableTable').value=at.table;
  const gc=JSON.parse(localStorage.getItem('gcal_cfg')||'{}');
  if(gc.id)$('gcalId').value=gc.id;
}

function saveGoals(){
  goals.protein=+$('goalPro').value||140;goals.calories=+$('goalCal').value||2000;
  goals.water=+$('goalWater').value||2.5;goals.sleep=+$('goalSleep').value||7;goals.weight=+$('goalWeight').value||65;
  svGoals();
  profile.height=+$('profileHeight').value||168;profile.age=+$('profileAge').value||23;
  profile.steps=+$('profileSteps').value||6000;svProfile();
  localStorage.setItem('airtable_cfg',JSON.stringify({key:$('airtableKey').value,base:$('airtableBase').value,table:$('airtableTable').value}));
  localStorage.setItem('gcal_cfg',JSON.stringify({id:$('gcalId').value}));
  toast('✅ Réglages sauvegardés');render();
}

// NAV
document.querySelectorAll('.tab').forEach(b=>{b.addEventListener('click',()=>{
  document.querySelectorAll('.tab').forEach(x=>x.classList.remove('active'));
  document.querySelectorAll('.page').forEach(x=>x.classList.remove('active'));
  b.classList.add('active');$(b.dataset.page).classList.add('active');})});

// MODALS
function openModal(id){closeModals();$(id).classList.add('open')}
function closeModals(){document.querySelectorAll('.modal-bg').forEach(m=>m.classList.remove('open'))}
document.querySelectorAll('.modal-bg').forEach(m=>{m.addEventListener('click',e=>{if(e.target===m)closeModals()})});
$('fabBtn').addEventListener('click',()=>openModal('modalSelect'));

// SAVE FUNCTIONS
function saveTrain(){
  const t=$('trainType').value,d=+$('trainDur').value||0,r=+$('trainRPE').value||0,n=$('trainNotes').value;
  if(!d){toast('⚠️ Durée requise');return}
  const entry={date:today(),type:t,dur:d,rpe:r,notes:n,id:Date.now()};
  data.trainings.push(entry);data.missed=data.missed.filter(m=>m.rescheduledTo!==today());sv();
  closeModals();toast('✅ Entraînement enregistré');
  $('trainDur').value='';$('trainRPE').value='';$('trainNotes').value='';
  pushToAirtable('Training',entry);render();
}
function saveSleep(){
  const b=$('sleepBed').value,w=$('sleepWake').value,q=+$('sleepQual').value||0;
  if(!b||!w){toast('⚠️ Heures requises');return}
  let bm=toMin(b),wm=toMin(w);if(wm<=bm)wm+=1440;
  const h=+((wm-bm)/60).toFixed(1);
  const entry={date:today(),bed:b,wake:w,hours:h,qual:q,id:Date.now()};
  data.sleep.push(entry);sv();closeModals();toast('✅ Sommeil enregistré');
  pushToAirtable('Sleep',entry);render();
}
function saveFood(){
  const ml=$('foodMeal').value,ds=$('foodDesc').value,ca=+$('foodCal').value||0,
    pr=+$('foodPro').value||0,wa=+$('foodWater').value||0,cr=$('foodCreatine').checked;
  const entry={date:today(),meal:ml,desc:ds,cal:ca,pro:pr,water:wa,creatine:cr,id:Date.now()};
  data.meals.push(entry);sv();closeModals();toast('✅ Repas enregistré');
  $('foodDesc').value='';$('foodCal').value='';$('foodPro').value='';$('foodWater').value='';$('foodCreatine').checked=false;
  pushToAirtable('Meal',entry);render();
}
function saveWeight(){
  const w=+$('weightInput').value;if(!w){toast('⚠️ Poids requis');return}
  const entry={date:today(),weight:w,id:Date.now()};
  data.weights.push(entry);sv();closeModals();toast('✅ Poids enregistré');
  $('weightInput').value='';pushToAirtable('Weight',entry);render();
}
function saveMissed(){
  const reason=$('missedReason').value;
  const tomorrow=new Date();tomorrow.setDate(tomorrow.getDate()+1);
  const tStr=tomorrow.toISOString().split('T')[0];
  const dow=(new Date().getDay()+6)%7;
  const plan=['🏃 Course facile','🏋️ Haut du corps','🚶 Repos','🏋️ Bas du corps','🏃 Fractionné','🔥 Circuit HYROX','😌 Repos'];
  const entry={date:today(),reason,session:plan[dow],rescheduledTo:tStr,id:Date.now()};
  data.missed.push(entry);sv();closeModals();toast('📅 Séance reportée à demain');
  addToGoogleCalendar(entry);render();
}

// AIRTABLE
function getAirtableCfg(){return JSON.parse(localStorage.getItem('airtable_cfg')||'{}')}
async function pushToAirtable(type,entry){
  const cfg=getAirtableCfg();if(!cfg.key||!cfg.base)return;
  const url=`https://api.airtable.com/v0/${cfg.base}/${encodeURIComponent(cfg.table||'Tracker')}`;
  try{const res=await fetch(url,{method:'POST',headers:{'Authorization':`Bearer ${cfg.key}`,'Content-Type':'application/json'},
    body:JSON.stringify({fields:{Type:type,Date:entry.date,Data:JSON.stringify(entry)}})});
    if(res.ok){$('syncStatus').textContent='☁️ Synced';$('syncStatus').className='sync-status ok'}
    else{$('syncStatus').textContent='⚠️ Sync failed';$('syncStatus').className='sync-status err'}
  }catch{$('syncStatus').textContent='⚠️ Offline';$('syncStatus').className='sync-status err'}}
async function syncToAirtable(){
  const cfg=getAirtableCfg();if(!cfg.key||!cfg.base){toast('⚠️ Configure Airtable dans ⚙️');return}
  toast('☁️ Synchronisation...');
  const url=`https://api.airtable.com/v0/${cfg.base}/${encodeURIComponent(cfg.table||'Tracker')}`;
  const all=[...data.trainings.map(e=>({Type:'Training',Date:e.date,Data:JSON.stringify(e)})),
    ...data.sleep.map(e=>({Type:'Sleep',Date:e.date,Data:JSON.stringify(e)})),
    ...data.meals.map(e=>({Type:'Meal',Date:e.date,Data:JSON.stringify(e)})),
    ...data.weights.map(e=>({Type:'Weight',Date:e.date,Data:JSON.stringify(e)}))];
  for(let i=0;i<all.length;i+=10){const batch=all.slice(i,i+10).map(f=>({fields:f}));
    try{await fetch(url,{method:'POST',headers:{'Authorization':`Bearer ${cfg.key}`,'Content-Type':'application/json'},
      body:JSON.stringify({records:batch})})}catch(err){toast('❌ Erreur: '+err.message);return}}
  toast('✅ Synchronisé sur Airtable');$('syncStatus').textContent='☁️ Fully synced';$('syncStatus').className='sync-status ok'}
async function testAirtable(){
  const cfg={key:$('airtableKey').value,base:$('airtableBase').value,table:$('airtableTable').value};
  if(!cfg.key||!cfg.base){toast('⚠️ Remplis les champs');return}
  try{const res=await fetch(`https://api.airtable.com/v0/${cfg.base}/${encodeURIComponent(cfg.table||'Tracker')}?maxRecords=1`,
    {headers:{'Authorization':`Bearer ${cfg.key}`}});
    toast(res.ok?'✅ Connexion OK':'❌ Erreur: '+res.status)}catch(e){toast('❌ '+e.message)}}

// GOOGLE CALENDAR
function addToGoogleCalendar(missed){
  const cfg=JSON.parse(localStorage.getItem('gcal_cfg')||'{}');if(!cfg.id)return;
  const title=encodeURIComponent('🏋️ '+missed.session+' (reporté)');
  const date=missed.rescheduledTo.replace(/-/g,'');
  window.open(`https://calendar.google.com/calendar/render?action=TEMPLATE&text=${title}&dates=${date}/${date}&details=Reporté+depuis+${missed.date}`,'_blank');
}
function syncGoogleCalendar(){
  const cfg=JSON.parse(localStorage.getItem('gcal_cfg')||'{}');
  if(!cfg.id){toast('⚠️ Configure Google Calendar dans ⚙️');return}
  const now=new Date(),dow=(now.getDay()+6)%7;
  const plan=['🏃 Course facile','🏋️ Haut du corps','🚶 Repos','🏋️ Bas du corps','🏃 Fractionné','🔥 Circuit HYROX','😌 Repos'];
  const d=new Date(now);d.setDate(d.getDate()-dow);
  for(let i=0;i<7;i++){if(plan[i].includes('Repos'))continue;
    const dd=new Date(d);dd.setDate(d.getDate()+i);const ds=dd.toISOString().split('T')[0].replace(/-/g,'');
    const title=encodeURIComponent(plan[i]);
    if(i===0)window.open(`https://calendar.google.com/calendar/render?action=TEMPLATE&text=${title}&dates=${ds}T070000/${ds}T080000`,'_blank')}
  toast('📅 Google Calendar ouvert');}
function testGCal(){localStorage.setItem('gcal_cfg',JSON.stringify({id:$('gcalId').value}));toast('✅ Google Calendar configuré');}

// EXPORT CSV
function exportCSV(){
  let csv='Type,Date,Detail1,Detail2,Detail3,Detail4,Detail5\n';
  data.trainings.forEach(e=>{csv+=`Training,${e.date},"${e.type}",${e.dur},${e.rpe},"${(e.notes||'').replace(/"/g,"'")}",\n`});
  data.sleep.forEach(e=>{csv+=`Sleep,${e.date},${e.bed},${e.wake},${e.hours},${e.qual},\n`});
  data.meals.forEach(e=>{csv+=`Meal,${e.date},"${e.meal}",${e.cal},${e.pro},${e.water},${e.creatine}\n`});
  data.weights.forEach(e=>{csv+=`Weight,${e.date},${e.weight},,,,\n`});
  data.missed.forEach(e=>{csv+=`Missed,${e.date},"${e.session}","${e.reason}","${e.rescheduledTo}",,\n`});
  const blob=new Blob([csv],{type:'text/csv'});const url=URL.createObjectURL(blob);
  const a=document.createElement('a');a.href=url;a.download=`hyrox_export_${today()}.csv`;a.click();
  URL.revokeObjectURL(url);toast('📥 CSV exporté');}

// CALORIE CALCULATOR (Mifflin-St Jeor)
function calculateTDEE(){
  const lastW=data.weights.length?[...data.weights].sort((a,b)=>b.id-a.id)[0].weight:73;
  const bmr=10*lastW+6.25*profile.height-5*profile.age+5;
  const stepsCalories=(profile.steps||6000)*0.04;
  const neat=bmr*0.2+stepsCalories;
  const tef=bmr*0.1;
  let eat=0;const todayT=todayE(data.trainings);
  const metValues={'🏃 Course facile':8,'🏃 Fractionné':11,'🏋️ Haut du corps':5,'🏋️ Bas du corps':6,
    '🔥 Circuit HYROX':9.5,'🔥 Simulation':10,'🚶 Marche active':3.5,'🧘 Mobilité / Récupération':2.5};
  todayT.forEach(t=>{const met=metValues[t.type]||5;eat+=met*lastW*(t.dur/60)});
  const tdee=bmr+neat+tef+eat;
  const deficit=350;const target=Math.round(tdee-deficit);
  const protein=Math.round(lastW*2);const proteinCal=protein*4;
  const fat=Math.round(lastW*0.8);const fatCal=fat*9;
  const carbsCal=target-proteinCal-fatCal;const carbs=Math.max(0,Math.round(carbsCal/4));
  return{bmr:Math.round(bmr),neat:Math.round(neat),tef:Math.round(tef),eat:Math.round(eat),
    tdee:Math.round(tdee),target,protein,carbs,fat};}

