// CALENDAR
function renderCalendar(){
  const grid=$('calGrid');grid.innerHTML='';
  const months=['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];
  $('calTitle').textContent=months[calMonth]+' '+calYear;
  ['L','M','M','J','V','S','D'].forEach(d=>{grid.innerHTML+=`<div class="cal-header">${d}</div>`});
  const first=new Date(calYear,calMonth,1);const startDay=(first.getDay()+6)%7;
  const daysInMonth=new Date(calYear,calMonth+1,0).getDate();const todayStr=today();
  for(let i=0;i<startDay;i++)grid.innerHTML+='<div class="cal-day empty-day"></div>';
  for(let d=1;d<=daysInMonth;d++){
    const ds=`${calYear}-${String(calMonth+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    let cls='cal-day';if(ds===todayStr)cls+=' today-cal';
    if(data.trainings.some(t=>t.date===ds))cls+=' has-training';
    else if(data.missed.some(m=>m.date===ds))cls+=' has-missed';
    if(data.missed.some(m=>m.rescheduledTo===ds))cls+=' has-rescheduled';
    grid.innerHTML+=`<div class="${cls}" onclick="showDayDetail('${ds}')">${d}</div>`;}}
function changeMonth(delta){calMonth+=delta;if(calMonth>11){calMonth=0;calYear++}if(calMonth<0){calMonth=11;calYear--}renderCalendar();}
function showDayDetail(ds){
  const t=data.trainings.filter(e=>e.date===ds),s=data.sleep.filter(e=>e.date===ds),
    m=data.meals.filter(e=>e.date===ds),w=data.weights.filter(e=>e.date===ds),mi=data.missed.filter(e=>e.date===ds);
  let msg=`📅 ${fmt(ds)}\n\n`;
  if(t.length)msg+=`🏋️ ${t.length} entraînement(s): ${t.map(x=>x.type+' '+x.dur+'min').join(', ')}\n`;
  if(s.length)msg+=`😴 Sommeil: ${s[0].hours}h (${s[0].bed}→${s[0].wake})\n`;
  if(m.length)msg+=`🍽️ ${m.length} repas: ${m.reduce((a,x)=>a+x.cal,0)} kcal, ${m.reduce((a,x)=>a+x.pro,0)}g prot\n`;
  if(w.length)msg+=`⚖️ Poids: ${w[0].weight}kg\n`;
  if(mi.length)msg+=`❌ Manqué: ${mi[0].session} → reporté au ${mi[0].rescheduledTo}\n`;
  if(!t.length&&!s.length&&!m.length&&!w.length&&!mi.length)msg+='Aucune donnée.';alert(msg);}
function renderRescheduled(){
  const c=$('rescheduledList');const active=data.missed.filter(m=>{
    return!data.trainings.some(t=>t.date===m.rescheduledTo)&&m.rescheduledTo>=today()});
  if(!active.length){c.innerHTML='<div class="empty"><div class="emoji">✅</div><p>Toutes les séances sont à jour !</p></div>';return}
  c.innerHTML=active.map(m=>`<div class="log-item"><div class="log-dot" style="background:var(--accent2)"></div>
    <div class="log-body"><h4>${m.session}</h4><p>Manquée le ${fmt(m.date)} · ${m.reason}</p></div>
    <div class="log-right">📅 ${fmt(m.rescheduledTo)}</div></div>`).join('');}

// RENDER ALL
function render(){
  renderHeader();renderCountdown();renderWeek();renderRings();renderTDEE();
  renderWeight();renderMainChart();renderSleepChart();renderTrainWeekChart();
  renderMacroChart();renderCalendar();renderRescheduled();
  renderTodayPlan();renderTrainLog();renderSleepLog();renderFoodPage();loadGoalsUI();}
function renderHeader(){
  const d=new Date(),days=['Dimanche','Lundi','Mardi','Mercredi','Jeudi','Vendredi','Samedi'],
    months=['janvier','février','mars','avril','mai','juin','juillet','août','septembre','octobre','novembre','décembre'];
  $('headerDate').textContent=`${days[d.getDay()]} ${d.getDate()} ${months[d.getMonth()]}`;
  const w=Math.floor((new Date()-START)/(7*864e5));let p='PHASE 1 · FONDATIONS';
  if(w>=22)p='PHASE 4 · AFFÛTAGE';else if(w>=16)p='PHASE 3 · SPÉCIFIQUE';else if(w>=8)p='PHASE 2 · CONSTRUCTION';
  $('phaseBadge').textContent=p;}
function renderCountdown(){
  const diff=Math.max(0,Math.ceil((RACE-new Date())/864e5));$('daysLeft').textContent=diff;
  const total=Math.ceil((RACE-START)/864e5),elapsed=total-diff,pct=Math.min(100,Math.round(elapsed/total*100));
  $('countPct').textContent=pct+'%';$('countRing').style.strokeDashoffset=157-157*pct/100;}
function renderWeek(){
  const g=$('weekGrid');g.innerHTML='';const now=new Date(),dow=(now.getDay()+6)%7;
  const labels=['L','M','M','J','V','S','D'],plan=[1,1,0,1,1,1,0];
  for(let i=0;i<7;i++){const d=new Date(now);d.setDate(d.getDate()-dow+i);
    const ds=d.toISOString().split('T')[0],isToday=i===dow,
      has=data.trainings.some(t=>t.date===ds),isPast=i<dow,isRest=!plan[i],
      isRescheduled=data.missed.some(m=>m.rescheduledTo===ds);
    let c='day';if(isToday)c+=' today';if(has)c+=' done';
    else if(isRescheduled)c+=' rescheduled';else if(isPast&&!isRest)c+=' missed';if(isRest)c+=' rest';
    g.innerHTML+=`<div class="${c}"><div class="dl">${labels[i]}</div><div class="dn">${d.getDate()}</div><div class="dot"></div></div>`;}}
function renderRings(){
  const c=188.5,tt=todayE(data.trainings),tp=tt.length>0?100:0;
  $('ringTrain').style.strokeDashoffset=c-c*tp/100;$('ringTrainVal').textContent=tt.length>0?'✓':'0';
  const ts=todayE(data.sleep),sh=ts.length?ts[ts.length-1].hours:0,sp=Math.min(100,Math.round(sh/goals.sleep*100));
  $('ringSleep').style.strokeDashoffset=c-c*sp/100;$('ringSleepVal').textContent=sh>0?sh+'h':'—';
  const tm=todayE(data.meals),tp2=tm.reduce((s,m)=>s+m.pro,0),pp=Math.min(100,Math.round(tp2/goals.protein*100));
  $('ringCal').style.strokeDashoffset=c-c*pp/100;$('ringCalVal').textContent=tp2+'g';}
function renderTDEE(){
  const t=calculateTDEE();
